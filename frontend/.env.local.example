# Frontend Environment Variables
# Copy this file to .env.local and update values as needed

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws

# API Authentication (Phase 1)
# Must match one of the backend API keys (see backend/.env)
# Dev key for local development
NEXT_PUBLIC_API_KEY=syauai_dev_key_12345

# Alternative keys for testing:
# NEXT_PUBLIC_API_KEY=syauai_test_key_67890
