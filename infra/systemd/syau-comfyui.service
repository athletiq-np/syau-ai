[Unit]
Description=SYAU ComfyUI Server
After=network.target

[Service]
Type=simple
User=ekduiteen
WorkingDirectory=/data/ComfyUI
ExecStart=/usr/bin/tmux new-session -d -s syau-comfyui 'cd /data/ComfyUI && ./venv/bin/python main.py --listen 0.0.0.0 --port 8188 > /tmp/comfyui-live.log 2>&1'
ExecStop=/usr/bin/tmux kill-session -t syau-comfyui
RemainAfterExit=yes
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
